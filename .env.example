# Discord bot credentials — get these from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here
DISCORD_GUILD_ID=your_server_id_here

# Database path (default works for local dev; Docker sets this to /app/data/prism.db)
DB_PATH=./data/prism.db

# Node environment
NODE_ENV=development
